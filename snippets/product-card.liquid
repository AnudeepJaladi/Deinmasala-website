{% comment %}
  Reusable dynamic bestseller/product card
{% endcomment %}
{% assign variant = product.selected_or_first_available_variant %}
{% if variant %}
  {% assign product_category = 'other' %}
  {% assign product_type = product.type | downcase %}
  {% assign product_handle = product.handle | downcase %}
  {% assign product_tags = product.tags | join: ',' | downcase %}
  {% assign product_title = product.title | downcase %}

  {% if product_type contains 'dal' or product_type contains 'lentil' or product_type contains 'reis' or product_type contains 'rice' or product_tags contains 'rice' or product_tags contains 'dal' or product_tags contains 'riceanddal' or product_tags contains 'rice & dal' %}
    {% assign product_category = 'rice' %}
  {% elsif product_type contains 'snack' or product_type contains 'namkeen' or product_type contains 'chip' or product_tags contains 'snacks' or product_tags contains 'namkeen' %}
    {% assign product_category = 'snacks' %}
  {% elsif product_type contains 'süß' or product_type contains 'sweet' or product_type contains 'mithai' or product_tags contains 'sweets' or product_tags contains 'mithai' or product_tags contains 'dessert' %}
    {% assign product_category = 'sweets' %}
  {% elsif product_type contains 'mehl' or product_type contains 'mehl & getreide' or product_type contains 'mehl' or product_type contains 'flour' or product_type contains 'grain' or product_tags contains 'flour' or product_tags contains 'atta' or product_tags contains 'wheat' or product_tags contains 'ragi' %}
    {% assign product_category = 'flour' %}
  {% elsif product_type contains 'pickle' or product_type contains 'achar' or product_tags contains 'pickle' or product_tags contains 'pickles' or product_title contains 'achar' %}
    {% assign product_category = 'pickles' %}
  {% elsif product_type contains 'frozen' or product_type contains 'kühl' or product_type contains 'gefr' or product_tags contains 'frozen' %}
    {% assign product_category = 'frozen' %}
  {% elsif product_type contains 'chai' or product_type contains 'tea' or product_type contains 'beverage' or product_type contains 'getränk' or product_tags contains 'beverages' or product_tags contains 'tea' or product_tags contains 'chai' %}
    {% assign product_category = 'beverages' %}
  {% elsif product_type contains 'puja' or product_type contains 'incense' or product_tags contains 'puja' or product_tags contains 'incense' %}
    {% assign product_category = 'puja' %}
  {% elsif product_type contains 'kcal' or product_type contains 'öl' or product_type contains 'ghee' or product_type contains 'oil' or product_type contains 'koch' or product_tags contains 'oil' or product_tags contains 'ghee' %}
    {% assign product_category = 'cooking' %}
  {% elsif product_type contains 'frisch' or product_type contains 'fresh' or product_tags contains 'fresh' or product_tags contains 'produce' %}
    {% assign product_category = 'fresh' %}
  {% elsif product_tags contains 'spices' or product_type contains 'gewürz' or product_type contains 'masala' or product_handle contains 'spice' or product_handle contains 'masala' %}
    {% assign product_category = 'spices' %}
  {% elsif product_category == 'other' and product_tags contains 'other' == false %}
    {% if product_handle contains 'chili' or product_handle contains 'chilli' or product_handle contains 'haldi' or product_handle contains 'turmer' %}
      {% assign product_category = 'spices' %}
    {% endif %}
  {% endif %}

  {% assign product_badge = '' %}
  {% assign product_badge_class = '' %}
  {% if product.tags contains 'bestseller' or product.tags contains 'top' %}
    {% assign product_badge = 'Bestseller' %}
    {% assign product_badge_class = 'badge-bestseller' %}
  {% elsif product.tags contains 'new' %}
    {% assign product_badge = 'Neu' %}
    {% assign product_badge_class = 'badge-new' %}
  {% elsif product.tags contains 'hot' or product.tags contains 'trending' %}
    {% assign product_badge = '🔥 Heiß' %}
    {% assign product_badge_class = 'badge-hot' %}
  {% elsif product.compare_at_price > variant.price and product.compare_at_price > 0 and variant.compare_at_price > variant.price %}
    {% assign product_badge = '-15%' %}
    {% assign product_badge_class = 'badge-sale' %}
  {% endif %}

  <div class="product-card" data-category="{{ product_category }}">
    <div class="product-img-wrap">
      <a href="{{ product.url }}" class="product-link" aria-label="{{ product.title }}">
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title | escape }}" class="product-image" />
        {% else %}
          <span class="product-emoji">🛒</span>
        {% endif %}
      </a>

      {% if product_badge != blank %}
        <div class="product-badges">
          <span class="{{ product_badge_class }}">{{ product_badge }}</span>
        </div>
      {% endif %}

      <button class="product-wishlist" aria-label="Merken">♡</button>
    </div>

    <div class="product-info">
      <span class="product-brand">{{ product.vendor }}</span>
        <a href="{{ product.url }}"><h3 class="product-name">{{ product.title }}</h3></a>
      <p class="product-desc">{{ product.description | strip_html | truncate: 90 }}</p>

      <div class="product-rating">
        <span class="stars">★★★★★</span>
        <span class="rating-count">(0)</span>
      </div>

      <div class="product-price-row">
        <span class="product-price">{{ variant.price | money }}</span>
      </div>

      {% render 'shopify-product-form', product_handle: product.handle, button_class: 'btn-primary btn-full', button_label: 'In den Warenkorb' %}
    </div>
  </div>
{% endif %}
