<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }} – {{ page_title }}</title>
    <meta name="description" content="{{ page_description | default: shop.description | strip_html | truncate: 160 }}">
    {{ content_for_header }}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    {{ 'styles.css' | asset_url | stylesheet_tag }}
    {{ 'script.js' | asset_url | script_tag }}
  </head>
  <body class="{{ template }}">
    {{ content_for_layout }}
  </body>
</html>
